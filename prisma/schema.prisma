generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  name          String?
  role          Role           @default(CUSTOMER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[] @relation("CustomerConversations")
  messages      Message[]      @relation("SenderMessages")
  reactions     Reaction[]
  tags          CustomerTag[]
}

enum Role {
  ADMIN
  CUSTOMER
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  subject    String
  status     Status    @default(OPEN)
  priority   Priority  @default(NORMAL)
  customerId String    @db.Uuid
  customer   User      @relation("CustomerConversations", fields: [customerId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   Message[]
  notes      ConversationNote[]
}

enum Status {
  OPEN
  CLOSED
  PENDING
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  content        String
  isDeleted      Boolean       @default(false)
  editedAt       DateTime?
  attachmentUrl  String?
  attachmentName String?
  conversationId String        @db.Uuid
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String        @db.Uuid
  sender         User          @relation("SenderMessages", fields: [senderId], references: [id])
  isRead         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  reactions      Reaction[]
}

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  emoji     String
  messageId String   @db.Uuid
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model PageContent {
  section   String   @id
  content   Json
  updatedAt DateTime @updatedAt
}

model QuickReply {
  id        String   @id @default(uuid()) @db.Uuid
  shortcut  String   @unique
  label     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  details    Json?
  adminEmail String
  createdAt  DateTime @default(now())
}

model ConversationNote {
  id             String       @id @default(uuid()) @db.Uuid
  content        String
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  adminEmail     String
  isInternal     Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model CustomerTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  color     String   @default("#3ecbac")
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, userId])
}
