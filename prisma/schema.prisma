generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  name          String?
  role          Role           @default(CUSTOMER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[] @relation("CustomerConversations")
  messages      Message[]      @relation("SenderMessages")
  reactions     Reaction[]
  tags          CustomerTag[]
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  subject    String
  status     Status    @default(OPEN)
  priority   Priority  @default(NORMAL)
  customerId String    @db.Uuid
  customer   User      @relation("CustomerConversations", fields: [customerId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   Message[]
  notes      ConversationNote[]

  @@index([customerId])
  @@index([updatedAt(sort: Desc)])
  @@index([status])
}

enum Status {
  OPEN
  CLOSED
  PENDING
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  content        String
  isDeleted      Boolean       @default(false)
  editedAt       DateTime?
  attachmentUrl  String?
  attachmentName String?
  conversationId String        @db.Uuid
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String        @db.Uuid
  sender         User          @relation("SenderMessages", fields: [senderId], references: [id])
  isRead         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  reactions      Reaction[]

  @@index([conversationId])
  @@index([isRead])
  @@index([conversationId, isRead])
}

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  emoji     String
  messageId String   @db.Uuid
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model PageContent {
  section     String        @id
  content     Json
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  updatedAt   DateTime      @updatedAt
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model QuickReply {
  id        String   @id @default(uuid()) @db.Uuid
  shortcut  String   @unique
  label     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  details    Json?
  adminEmail String
  createdAt  DateTime @default(now())
}

model ConversationNote {
  id             String       @id @default(uuid()) @db.Uuid
  content        String
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  adminEmail     String
  isInternal     Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
}

model CustomerTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  color     String   @default("#3ecbac")
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, userId])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  sku         String   @unique
  description String?
  price       Float    @default(0)
  cost        Float    @default(0)
  stock       Int      @default(0)
  lowStockAt  Int      @default(5)
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sku])
  @@index([category])
  @@index([isActive])
}

model FAQ {
  id        String   @id @default(uuid()) @db.Uuid
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}
